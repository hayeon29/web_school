<!DOCTYPE html>
<html lang="en">
<%- include('layouts/header') -%>
<link rel="stylesheet" href="/css/content_web_style.css">
<body>
    <%- include('layouts/navbar') -%>
    <article>
        <div class = "content_wrap">
            <div class = "title_wrap">
                <div class = "content_title bold"><%= anonyboard.title %></div>
            </div>
            <div class = "name_date_wrap">
                <span class = "contents_bold content_name bold">작성자</span>
                <span class = "contents content_name"><%= anonyboard.writer %></span>
                <span class = "contents_bold content_date bold"></span>
                <span class = "contents content_date"><%= moment(anonyboard.date).format('YYYY-MM-DD') %></span>
                <span class = "contents_bold content_watch bold">조회수</span>
                <span class = "contents content_watch"><%= anonyboard.hits %></span>
            </div>
            <div class = "content_content">
                <%= content %>
            </div>
        </div>
    </article>
</body>
</html>